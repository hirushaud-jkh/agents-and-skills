{
  "inputs": [
    {
      "id": "azure-devops-pat",
      "type": "promptString",
      "description": "Azure DevOps Personal Access Token (needs: Work Items Read & Write, Project & Team Read)",
      "password": true
    }
  ],
  "servers": {
    "azure-devops": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@azure-devops/mcp", "JKGroupAA"],
      "env": {
        "AZURE_DEVOPS_EXT_PAT": "${input:azure-devops-pat}"
      }
    }
  }
}
